{
  "name": "@blueprint/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@blueprint/shared": "*",
    "@blueprint/ai-engine": "*",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/cookie": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.0",
    "drizzle-kit": "^0.30.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0",
    "stripe": "^17.0.0",
    "@google/generative-ai": "^0.21.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/bcryptjs": "^2.4.0",
    "@blueprint/tsconfig": "*"
  }
}

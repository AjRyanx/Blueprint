{
  "name": "blueprint",
  "private": true,
  "version": "0.1.0",
  "description": "Guided AI-Powered Software Development Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "db:generate": "cd apps/api && npm run db:generate",
    "db:push": "cd apps/api && npm run db:push",
    "db:studio": "cd apps/api && npm run db:studio"
  },
  "devDependencies": {
    "@next/swc-win32-x64-msvc": "^16.2.6",
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.9.14",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.0"
}
